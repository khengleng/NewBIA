{
  "name": "mobile-bot-service",
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile and Telegram Bot Service for BIA Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx prisma generate --schema=./prisma/schema.prisma && tsc",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "test": "sh -c 'ls src/**/*.test.ts >/dev/null 2>&1 && tsx --test src/**/*.test.ts || echo \"test skipped (no tests)\"'",
    "lint": "echo \"lint skipped (no eslint config)\""
  },
  "dependencies": {
    "multer": "^1.4.5-lts.1",
    "@google/generative-ai": "^0.24.1",
    "prisma": "5.7.1",
    "@prisma/client": "5.7.1",
    "axios": "^1.7.9",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-telegram-bot-api": "^0.64.0",
    "ioredis": "^5.3.2",
    "zod": "^3.23.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/multer": "^1.4.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/node-telegram-bot-api": "^0.64.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
