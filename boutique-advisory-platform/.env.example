# Local multi-service Docker environment
# Copy to .env and fill secrets for local runs.

# Core/auth secrets
JWT_SECRET=change-me-local-jwt
JWT_REFRESH_SECRET=change-me-local-refresh
SESSION_SECRET=change-me-local-session
COOKIE_SECRET=change-me-local-cookie
CSRF_SECRET=change-me-local-csrf
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
INITIAL_ADMIN_PASSWORD=SecurePassword123!

# URLs and CORS
CORS_ORIGIN=http://localhost:3002
FRONTEND_URL=http://localhost:3002
TRADING_FRONTEND_URL=http://localhost:3016
TRADING_FRONTEND_HOST=localhost:3016

# Optional service settings
SERVICE_VERSION=local
MOBILE_APP_URL=http://localhost:4173

# Bot integration
TELEGRAM_BOT_TOKEN=
INTERNAL_API_KEY=dev-internal-key
