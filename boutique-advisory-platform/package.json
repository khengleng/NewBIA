{
    "name": "boutique-advisory-platform",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "*-service",
        "core-backend",
        "trade-api",
        "*-frontend",
        "bridge"
    ],
    "scripts": {
        "install:all": "npm install",
        "build": "npm run build --workspaces --if-present",
        "test": "npm test --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "dev": "npm run dev --workspaces --parallel",
        "db:generate": "npm run db:generate --workspaces --if-present",
        "db:push": "npm run db:push --workspaces --if-present",
        "test:smoke": "node scripts/railway-smoke-security.mjs",
        "test:smoke:railway": "node scripts/railway-smoke-security.mjs --base-url $SMOKE_BASE_URL",
        "test:security:gate": "npm run test --workspaces --if-present",
        "deploy:backend:canary": "bash scripts/deploy-backend-canary.sh",
        "deploy:backend:canary:local": "bash scripts/deploy-backend-canary.sh \"$HOME/BIA\""
    }
}
