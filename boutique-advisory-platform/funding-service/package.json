{
  "name": "bia-funding-service",
  "version": "1.0.0",
  "private": true,
  "description": "Dedicated funding and payments microservice for trade.cambobia.com and twallet money movement flows",
  "scripts": {
    "build": "npx prisma generate --schema=./prisma/schema.prisma && tsc",
    "start": "npx prisma generate --schema=./prisma/schema.prisma && tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "start:dev": "npx prisma generate --schema=./prisma/schema.prisma && tsx watch src/index.ts",
    "test": "tsx --test src/**/*.test.ts",
    "lint": "echo \"lint skipped (no eslint config)\""
  },
  "dependencies": {
    "multer": "^1.4.5-lts.1",
    "@google/generative-ai": "^0.24.1",
    "prisma": "5.7.1",
    "@prisma/client": "5.7.1",
    "@aws-sdk/client-s3": "^3.984.0",
    "@aws-sdk/s3-request-presigner": "^3.984.0",
    "@google-cloud/storage": "^7.19.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.1",
    "speakeasy": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "zod": "^3.23.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/multer": "^1.4.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.5",
    "@types/speakeasy": "^2.0.10",
    "@types/qrcode": "^1.5.6"
  }
}
